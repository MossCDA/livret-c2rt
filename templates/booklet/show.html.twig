{% extends 'base.html.twig' %}
{% block title %}Semaine {{ booklet.weekNumber }}{% endblock %}
{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3"><i class="bi bi-journal-text"></i> Semaine {{ booklet.weekNumber }}</h1>
    <div>
        {% if is_granted('ROLE_FORMATEUR') and not booklet.validated %}
        <form method="post" action="{{ path('app_booklet_validate', {id: booklet.id}) }}" style="display:inline">
            <input type="hidden" name="_token" value="{{ csrf_token('validate' ~ booklet.id) }}">
            <button class="btn btn-success"><i class="bi bi-check-circle"></i> Valider</button>
        </form>
        {% endif %}
        {% if not booklet.validated and booklet.user == app.user %}
        <a href="{{ path('app_booklet_edit', {id: booklet.id}) }}" class="btn btn-warning">
            <i class="bi bi-pencil"></i> Modifier
        </a>
        {% endif %}
        <a href="{{ path('app_booklet_index') }}" class="btn btn-secondary">Retour</a>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between">
        <span>
            <strong>{{ booklet.user ? booklet.user.firstName ~ ' ' ~ booklet.user.lastName : '-' }}</strong>
            — {{ booklet.weekStart ? booklet.weekStart|date('d/m/Y') : '-' }}
        </span>
        <span>
            {% if booklet.validated %}
                <span class="badge bg-success">Validé le {{ booklet.validatedAt|date('d/m/Y') }}</span>
            {% else %}
                <span class="badge bg-warning text-dark">En attente de validation</span>
            {% endif %}
        </span>
    </div>
    <div class="card-body">
        <p style="white-space: pre-wrap;">{{ booklet.weekContent }}</p>
    </div>
</div>
{% endblock %}