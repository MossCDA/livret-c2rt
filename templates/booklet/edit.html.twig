{% extends 'base.html.twig' %}
{% block title %}Modifier entrée{% endblock %}
{% block body %}
<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header"><h4><i class="bi bi-pencil"></i> Modifier — Semaine {{ booklet.weekNumber }}</h4></div>
            <div class="card-body">
                {{ form_start(form, {'attr': {'class': 'row g-3'}}) }}
                    <div class="col-md-6">{{ form_label(form.weekNumber) }}{{ form_widget(form.weekNumber) }}</div>
                    <div class="col-md-6">{{ form_label(form.weekStart) }}{{ form_widget(form.weekStart) }}</div>
                    <div class="col-12">{{ form_label(form.weekContent) }}{{ form_widget(form.weekContent) }}</div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-warning">Modifier</button>
                        <a href="{{ path('app_booklet_index') }}" class="btn btn-secondary">Annuler</a>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}