{% extends 'base.html.twig' %}

{% block title %}Nouvelle formation{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h4><i class="bi bi-plus-circle"></i> Nouvelle formation</h4>
            </div>
            <div class="card-body">
                {{ form_start(form, {'attr': {'class': 'row g-3'}}) }}
                    <div class="col-md-12">
                        {{ form_label(form.name) }}
                        {{ form_widget(form.name) }}
                        {{ form_errors(form.name) }}
                    </div>
                    <div class="col-md-6">
                        {{ form_label(form.beginAt) }}
                        {{ form_widget(form.beginAt) }}
                    </div>
                    <div class="col-md-6">
                        {{ form_label(form.endAt) }}
                        {{ form_widget(form.endAt) }}
                    </div>
                    <div class="col-md-6">
                        {{ form_label(form.beginStageAt) }}
                        {{ form_widget(form.beginStageAt) }}
                    </div>
                    <div class="col-md-6">
                        {{ form_label(form.endStageAt) }}
                        {{ form_widget(form.endStageAt) }}
                    </div>
                    <div class="col-md-6">
                        {{ form_label(form.timeCenter) }}
                        {{ form_widget(form.timeCenter) }}
                    </div>
                    <div class="col-md-6">
                        {{ form_label(form.timeStage) }}
                        {{ form_widget(form.timeStage) }}
                    </div>
                    <div class="col-md-12">
                        {{ form_label(form.typeFormation) }}
                        {{ form_widget(form.typeFormation) }}
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save"></i> Créer
                        </button>
                        <a href="{{ path('app_formation_index') }}" class="btn btn-secondary">Annuler</a>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}