{% extends 'base.html.twig' %}

{% block title %}{{ formation.name }}{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3"><i class="bi bi-mortarboard"></i> {{ formation.name }}</h1>
    <div>
        <a href="{{ path('app_formation_edit', {id: formation.id}) }}" class="btn btn-warning">
            <i class="bi bi-pencil"></i> Modifier
        </a>
        <a href="{{ path('app_formation_index') }}" class="btn btn-secondary">Retour</a>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">Informations</div>
            <div class="card-body">
                <p><strong>Titre professionnel :</strong> {{ formation.typeFormation ? formation.typeFormation.name : '-' }}</p>
                <p><strong>Début :</strong> {{ formation.beginAt ? formation.beginAt|date('d/m/Y') : '-' }}</p>
                <p><strong>Fin :</strong> {{ formation.endAt ? formation.endAt|date('d/m/Y') : '-' }}</p>
                <p><strong>Début stage :</strong> {{ formation.beginStageAt ? formation.beginStageAt|date('d/m/Y') : '-' }}</p>
                <p><strong>Fin stage :</strong> {{ formation.endStageAt ? formation.endStageAt|date('d/m/Y') : '-' }}</p>
                <p><strong>Heures centre :</strong> {{ formation.timeCenter ?? '-' }}</p>
                <p><strong>Heures stage :</strong> {{ formation.timeStage ?? '-' }}</p>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">Apprenants ({{ formation.booklets|length }})</div>
            <div class="card-body">
                {% if formation.booklets is empty %}
                    <p class="text-muted">Aucun apprenant pour l'instant.</p>
                {% else %}
                    <ul class="list-group">
                        {% for booklet in formation.booklets %}
                        <li class="list-group-item">
                            {{ booklet.user ? booklet.user.firstName ~ ' ' ~ booklet.user.lastName : 'Inconnu' }}
                        </li>
                        {% endfor %}
                    </ul>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}