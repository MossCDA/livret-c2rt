{% extends 'base.html.twig' %}

{% block title %}Formations{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3"><i class="bi bi-mortarboard"></i> Formations</h1>
    <a href="{{ path('app_formation_new') }}" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Nouvelle formation
    </a>
</div>

{% if formations is empty %}
    <div class="alert alert-info">Aucune formation créée pour l'instant.</div>
{% else %}
<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Nom</th>
                <th>Titre professionnel</th>
                <th>Début</th>
                <th>Fin</th>
                <th>Apprenants</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for formation in formations %}
            <tr>
                <td>{{ formation.name }}</td>
                <td>{{ formation.typeFormation ? formation.typeFormation.name : '-' }}</td>
                <td>{{ formation.beginAt ? formation.beginAt|date('d/m/Y') : '-' }}</td>
                <td>{{ formation.endAt ? formation.endAt|date('d/m/Y') : '-' }}</td>
                <td>{{ formation.booklets|length }}</td>
                <td>
                    <a href="{{ path('app_formation_show', {id: formation.id}) }}" class="btn btn-sm btn-info">
                        <i class="bi bi-eye"></i>
                    </a>
                    <a href="{{ path('app_formation_edit', {id: formation.id}) }}" class="btn btn-sm btn-warning">
                        <i class="bi bi-pencil"></i>
                    </a>
                    <form method="post" action="{{ path('app_formation_delete', {id: formation.id}) }}" style="display:inline" onsubmit="return confirm('Supprimer cette formation ?')">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ formation.id) }}">
                        <button class="btn btn-sm btn-danger"><i class="bi bi-trash"></i></button>
                    </form>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endif %}
{% endblock %}