{% extends 'base.html.twig' %}
{% block title %}Modifier ECF{% endblock %}
{% block body %}
<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card">
            <div class="card-header">
                <h4><i class="bi bi-clipboard-check"></i> Modifier évaluation (ECF)</h4>
            </div>
            <div class="card-body">
                {{ form_start(form, {'attr': {'class': 'row g-3'}}) }}
                    <div class="col-md-4">{{ form_label(form.grade) }}{{ form_widget(form.grade) }}</div>
                    <div class="col-md-8">{{ form_label(form.skill) }}{{ form_widget(form.skill) }}</div>
                    <div class="col-12">{{ form_label(form.comment) }}{{ form_widget(form.comment) }}</div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-warning">Modifier</button>
                        <a href="{{ path('app_booklet_show', {id: ecf.booklet.id}) }}" class="btn btn-secondary">Annuler</a>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}