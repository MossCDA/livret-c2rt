{% extends 'base.html.twig' %}
{% block title %}Nouveau titre professionnel{% endblock %}
{% block body %}
<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header"><h4>Nouveau titre professionnel</h4></div>
            <div class="card-body">
                {{ form_start(form, {'attr': {'class': 'row g-3'}}) }}
                    <div class="col-12">{{ form_label(form.name) }}{{ form_widget(form.name) }}</div>
                    <div class="col-12">{{ form_label(form.code) }}{{ form_widget(form.code) }}</div>
                    <div class="col-12">{{ form_label(form.detail) }}{{ form_widget(form.detail) }}</div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-primary">Créer</button>
                        <a href="{{ path('app_type_formation_index') }}" class="btn btn-secondary">Annuler</a>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}