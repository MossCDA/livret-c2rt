{% extends 'base.html.twig' %}
{% block title %}Titres professionnels{% endblock %}
{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3"><i class="bi bi-award"></i> Titres professionnels (RNCP)</h1>
    <a href="{{ path('app_type_formation_new') }}" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Nouveau titre
    </a>
</div>
{% if type_formations is empty %}
    <div class="alert alert-info">Aucun titre professionnel créé.</div>
{% else %}
<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr><th>Intitulé</th><th>Code RNCP</th><th>Description</th><th>Actions</th></tr>
    </thead>
    <tbody>
        {% for tf in type_formations %}
        <tr>
            <td>{{ tf.name }}</td>
            <td>{{ tf.code ?? '-' }}</td>
            <td>{{ tf.detail ?? '-' }}</td>
            <td>
                <a href="{{ path('app_type_formation_edit', {id: tf.id}) }}" class="btn btn-sm btn-warning">
                    <i class="bi bi-pencil"></i>
                </a>
                <form method="post" action="{{ path('app_type_formation_delete', {id: tf.id}) }}" style="display:inline" onsubmit="return confirm('Supprimer ?')">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ tf.id) }}">
                    <button class="btn btn-sm btn-danger"><i class="bi bi-trash"></i></button>
                </form>
            </td>
        </tr>
        {% endfor %}
    </tbody>
</table>
{% endif %}
{% endblock %}