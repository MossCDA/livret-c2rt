{% extends 'base.html.twig' %}

{% block title %}Dashboard - Livret C2RT{% endblock %}

{% block stylesheets %}
<style>
    body {
        background: #0f1117;
        color: #e2e8f0;
    }

    .c2rt-dashboard {
        padding: 2rem 1rem;
    }

    .c2rt-header {
        margin-bottom: 2rem;
        border-left: 4px solid #00d4ff;
        padding-left: 1rem;
    }

    .c2rt-header h1 {
        font-family: 'Courier New', monospace;
        font-size: 1.6rem;
        font-weight: 700;
        color: #00d4ff;
        margin: 0 0 0.3rem 0;
    }

    .c2rt-header p {
        color: #64748b;
        font-size: 0.85rem;
        margin: 0;
        font-family: monospace;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .stat-card {
        background: #1a1d27;
        border: 1px solid #2a2d3e;
        border-radius: 12px;
        padding: 1.5rem;
        position: relative;
        overflow: hidden;
        transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
        text-decoration: none;
        display: block;
    }

    .stat-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 30px rgba(0,212,255,0.15);
        text-decoration: none;
    }

    .stat-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 3px;
        background: var(--accent);
    }

    .stat-card.cyan  { --accent: #00d4ff; }
    .stat-card.cyan:hover  { border-color: #00d4ff; }
    .stat-card.violet { --accent: #7c3aed; }
    .stat-card.violet:hover { border-color: #7c3aed; }
    .stat-card.green  { --accent: #10b981; }
    .stat-card.green:hover  { border-color: #10b981; }
    .stat-card.orange { --accent: #f59e0b; }
    .stat-card.orange:hover { border-color: #f59e0b; }

    .stat-icon {
        font-size: 1.8rem;
        color: var(--accent);
        margin-bottom: 0.8rem;
    }

    .stat-label {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: #64748b;
        font-family: monospace;
        margin-bottom: 0.4rem;
    }

    .stat-value {
        font-size: 3rem;
        font-weight: 800;
        color: #f1f5f9;
        line-height: 1;
        font-family: 'Courier New', monospace;
    }

    .stat-sub {
        font-size: 0.75rem;
        color: #475569;
        margin-top: 0.4rem;
        font-family: monospace;
    }

    .c2rt-status {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        color: #64748b;
        font-size: 0.78rem;
        font-family: monospace;
        border-top: 1px solid #1e2130;
        padding-top: 1.5rem;
    }

    .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #10b981;
        animation: blink 2s infinite;
        flex-shrink: 0;
    }

    @keyframes blink {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.2; }
    }

    /* override navbar bootstrap pour dark */
    .navbar.bg-primary {
        background: #111827 !important;
        border-bottom: 1px solid #1e2130;
    }

    .container-fluid.mt-4 {
        background: #0f1117;
        min-height: calc(100vh - 60px);
    }
</style>
{% endblock %}

{% block body %}
<div class="c2rt-dashboard">

    <div class="c2rt-header">
        <h1>// TABLEAU DE BORD</h1>
        <p>Centre de Ressources et de Formation C2RT &mdash; Vue administrative</p>
    </div>

    <div class="stats-grid">
        <a href="{{ path('admin_formation_index') }}" class="stat-card cyan">
            <div class="stat-icon"><i class="bi bi-mortarboard-fill"></i></div>
            <div class="stat-label">Formations</div>
            <div class="stat-value">{{ stats.formations }}</div>
            <div class="stat-sub">formations enregistr&eacute;es</div>
        </a>

        <a href="{{ path('admin_booklet_index') }}" class="stat-card violet">
            <div class="stat-icon"><i class="bi bi-journal-text"></i></div>
            <div class="stat-label">Livrets</div>
            <div class="stat-value">{{ stats.livrets }}</div>
            <div class="stat-sub">livrets actifs</div>
        </a>

        <a href="{{ path('admin_user_index') }}" class="stat-card green">
            <div class="stat-icon"><i class="bi bi-people-fill"></i></div>
            <div class="stat-label">Utilisateurs</div>
            <div class="stat-value">{{ stats.users }}</div>
            <div class="stat-sub">comptes enregistr&eacute;s</div>
        </a>

        <a href="{{ path('admin_ecf_index') }}" class="stat-card orange">
            <div class="stat-icon"><i class="bi bi-file-earmark-check-fill"></i></div>
            <div class="stat-label">ECF</div>
            <div class="stat-value">{{ stats.ecf }}</div>
            <div class="stat-sub">&eacute;valuations</div>
        </a>
    </div>

    <div class="c2rt-status">
        <div class="status-dot"></div>
        <span>Syst&egrave;me op&eacute;rationnel &mdash; {{ "now"|date("d/m/Y H:i") }}</span>
    </div>

</div>
{% endblock %}
