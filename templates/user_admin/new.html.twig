{% extends 'base.html.twig' %}
{% block title %}Nouvel utilisateur{% endblock %}
{% block body %}
<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header"><h4>Nouvel utilisateur</h4></div>
            <div class="card-body">
                {{ form_start(form, {'attr': {'class': 'row g-3'}}) }}
                    <div class="col-md-6">{{ form_label(form.firstName) }}{{ form_widget(form.firstName) }}</div>
                    <div class="col-md-6">{{ form_label(form.lastName) }}{{ form_widget(form.lastName) }}</div>
                    <div class="col-12">{{ form_label(form.email) }}{{ form_widget(form.email) }}</div>
                    <div class="col-12">{{ form_label(form.roles) }}{{ form_widget(form.roles) }}</div>
                    <div class="col-12">{{ form_label(form.formation) }}{{ form_widget(form.formation) }}</div>
                    <div class="col-12">{{ form_label(form.plainPassword) }}{{ form_widget(form.plainPassword) }}</div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-primary">Créer</button>
                        <a href="{{ path('app_user_index') }}" class="btn btn-secondary">Annuler</a>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}